{
  "expo": {
    "name": "AAN Services",
    "slug": "aan-services",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "aanservices",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "in.aanservices.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Scan Aadhaar card during employee onboarding",
        "NSPhotoLibraryUsageDescription": "Upload Aadhaar photo from gallery",
        "NSPhotoLibraryAddUsageDescription": "Save onboarding PDFs to your photos"
      }
    },
    "android": {
      "package": "in.aanservices.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1E3A8A"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow AAN Services to access your photos to upload Aadhaar images.",
          "cameraPermission": "Allow AAN Services to use the camera to scan Aadhaar cards."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "46aa2c3f-121f-4f85-b2b5-cf15318ccbe1"
      }
    }
  }
}
